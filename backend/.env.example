# Copie este arquivo para .env (na raiz do projeto) e preencha os valores.
# NUNCA commite o arquivo .env — ele já está no .gitignore.

# ── App ──────────────────────────────────────────────
NODE_ENV=production
PORT=3001
CORS_ORIGIN=http://localhost:3000

# ── Banco de dados ───────────────────────────────────
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://copastur:${POSTGRES_PASSWORD}@postgres:5432/copastur_clevel

# ── Auth (JWT) ───────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=8h

# ── IA (Anthropic) ───────────────────────────────────
ANTHROPIC_API_KEY=

# ── Azure DevOps ─────────────────────────────────────
ADO_ORG=
ADO_PAT=
ADO_SYNC_PROJECTS=Q2-2026
SYNC_ADO_CRON=0 */4 * * *

# ── Microsoft Graph / Azure AD ───────────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_REDIRECT_URI=
GRAPH_SCOPES=User.Read Calendars.Read Mail.Read

# ── Freshservice ─────────────────────────────────────
FRESHSERVICE_API_KEY=
FRESHSERVICE_DOMAIN=
SYNC_FS_CRON=0 */2 * * *

# ── Work / Plane ─────────────────────────────────────
WORK_API_URL=
WORK_TOKEN=
SYNC_WORK_CRON=0 */3 * * *

# ── SmartLeader (OKRs) ────────────────────────────────
SMARTLEADER_API_URL=
SMARTLEADER_API_KEY=
SYNC_OKR_CRON=0 8 * * *
