# Copie este arquivo para .env na raiz do projeto e preencha os valores.
# Usado pelo docker-compose.yml (env_file + substituição de variáveis ${VAR}).
# NUNCA commite o arquivo .env — ele já está no .gitignore.

# ── Banco de dados ───────────────────────────────────
POSTGRES_PASSWORD=

# ── Auth (JWT) ───────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=8h

# ── Credenciais de integração (criptografia AES-256-GCM) ─
# Chave usada para cifrar as API keys salvas via painel Admin > API Keys.
# Gere com: openssl rand -hex 32
CREDENTIALS_ENC_KEY=

# ── IA (Anthropic) ───────────────────────────────────
ANTHROPIC_API_KEY=

# ── Azure DevOps ─────────────────────────────────────
ADO_ORG=
ADO_PAT=
ADO_SYNC_PROJECTS=Q2-2026

# ── Microsoft Graph / Azure AD ───────────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_REDIRECT_URI=
GRAPH_SCOPES=User.Read Calendars.Read Mail.Read

# ── Freshservice ─────────────────────────────────────
FRESHSERVICE_API_KEY=
FRESHSERVICE_DOMAIN=

# ── Work / Plane ─────────────────────────────────────
WORK_API_URL=
WORK_TOKEN=

# ── SmartLeader (OKRs) ────────────────────────────────
SMARTLEADER_API_URL=
SMARTLEADER_API_KEY=
